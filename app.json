{
  "expo": {
    "name": "RallyZone",
    "slug": "rallyzone",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rallyzone",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111110"
    },
    "ios": {
      "bundleIdentifier": "com.lyfield.rallyzone",
      "buildNumber": "14",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "RallyZone uses Face ID to protect your Secure Vault.",
        "NSCameraUsageDescription": "RallyZone does not use the camera.",
        "NSPhotoLibraryUsageDescription": "RallyZone does not access your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#111110"
      },
      "package": "com.lyfield.rallyzone",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "RallyZone uses Face ID to protect your Secure Vault."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "e63ad189-0a01-40c3-b59e-2564aa8750a2"
      }
    }
  }
}
